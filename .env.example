VITE_API_BASE_URL=
PORT=3000
CORS_ORIGINS=http://localhost:5173
UPLOAD_MAX_SIZE=10485760
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=60000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=funlearn
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
VITE_SENTRY_DSN=
LOG_LEVEL=info
NODE_ENV=development

# 邮件服务器配置（用于发送验证码）
# QQ邮箱示例：smtp.qq.com，密码为授权码（不是登录密码）
# 163邮箱示例：smtp.163.com
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@qq.com
EMAIL_PASS=your_smtp_auth_code
